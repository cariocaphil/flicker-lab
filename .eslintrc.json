{
  "root": true,
  "env": {
    "browser": true,
    "es2020": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react-hooks/recommended"
  ],
  "ignorePatterns": ["dist", "coverage", "vite.config.js", "vite.config.d.ts"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["react-refresh"],
  "rules": {
    "react-refresh/only-export-components": [
      "warn",
      { "allowConstantExport": true }
    ]
  },
  "overrides": [
    {
      "files": [
        "server/**/*.{ts,tsx}",
        "src/db/**/*.ts",
        "src/services/drizzleProjectRepository.ts"
      ],
      "env": {
        "node": true,
        "browser": false
      },
      "rules": {
        "react-refresh/only-export-components": "off"
      }
    }
  ]
}
